{
  "name": "nutritrackapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "api": "node server/index.js",
    "db": "docker run --name nutritrack-postgres -e POSTGRES_DB=nutritrack -e POSTGRES_USER=nutritrack -e POSTGRES_PASSWORD=nutritrack -p 5432:5432 -v nutritrack-postgres-data:/var/lib/postgresql/data -v \"$PWD/server/schema.sql:/docker-entrypoint-initdb.d/001-schema.sql:ro\" -d postgres:16",
    "db:migrate": "node server/migrate.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo": "~54.0.33",
    "expo-image-picker": "~17.0.11",
    "expo-status-bar": "~3.0.9",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "private": true
}
